# ── LiteLLM Proxy ─────────────────────────────────────────────────────────────
# Base URL of the LiteLLM proxy (no trailing slash).
LITELLM_BASE_URL=https://management.sprints.ai/litellm

# API key for authenticating with the LiteLLM proxy.
LITELLM_API_KEY=your-api-key-here

# ── Model Selection ───────────────────────────────────────────────────────────
# Chat / completion model identifier (as recognised by the LiteLLM proxy).
DEFAULT_MODEL=azure/FW-Kimi-K2.6

# Embedding model identifier (as recognised by the LiteLLM proxy).
DEFAULT_EMBEDDING_MODEL=text-embedding-ada-002

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# Example: postgresql://user:password@localhost:5432/career_coach
DATABASE_URL=postgresql://user:password@localhost:5432/career_coach
